---
interface Props {
  slug: string;
  title: string;
  itemCount: number;
}

const { slug, title, itemCount } = Astro.props;
---

<a href={`/vendors/${slug}/`} class="vendor-card">
  <span class="vendor-card-title">{title}</span>
  <span class="vendor-card-count">
    {itemCount} product{itemCount === 1 ? '' : 's'}
  </span>
</a>

<style>
  .vendor-card {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--color-text);
  }

  .vendor-card:hover {
    border-color: var(--color-border-strong);
    background: var(--color-bg-subtle);
  }

  .vendor-card-title {
    font-weight: 500;
    font-size: 15px;
  }

  .vendor-card-count {
    font-size: 12px;
    color: var(--color-text-muted);
  }
</style>
